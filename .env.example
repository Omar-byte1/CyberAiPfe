# ============================================================
#  CyberAI Environment Configuration
#  Copy this file to .env and fill in your keys
#  Command: copy .env.example .env
# ============================================================

# ----------------------------------------------------------
# Strategy C: ScraperAPI (CAPTCHA + Residential Proxies)
# ----------------------------------------------------------
# Free tier: 1,000 requests/month — https://www.scraperapi.com
# Only triggered when Strategy A (requests) AND Strategy B 
# (StealthyFetcher/Playwright) both fail.
# Leave empty to disable Strategy C gracefully.
SCRAPER_API_KEY=your_scraperapi_key_here

# ----------------------------------------------------------
# JWT Secret (change this in production!)
# ----------------------------------------------------------
SECRET_KEY=change-me-in-production-use-a-long-random-string

# ----------------------------------------------------------
# Optional: Alternative CAPTCHA solvers
# ----------------------------------------------------------
# 2Captcha (https://2captcha.com) — $0.001 per solve
# TWOCAPTCHA_API_KEY=your_2captcha_key_here

# CapSolver (https://capsolver.com) — $0.0008 per solve  
# CAPSOLVER_API_KEY=your_capsolver_key_here
